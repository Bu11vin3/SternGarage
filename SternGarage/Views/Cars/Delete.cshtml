@model Car
@{
    ViewData["Title"] = "Изтрий автомобил";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <h2 class="mb-4">Потвърдете изтриването</h2>

            <div class="card mb-3">
                <div class="card-body text-center">
                    <h4>@Model.Model</h4>
                    <p class="text-muted">@Model.Year | @Model.Class?.Name | @Model.Horsepower к.с.</p>
                </div>
            </div>

            <div class="alert alert-warning">
                <strong>Внимание!</strong> Това действие е необратимо.
                @if (Model.Reviews?.Count > 0)
                {
                    <span>Всички @Model.Reviews.Count отзива също ще бъдат изтрити.</span>
                }
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Изтрий</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Отказ</a>
                </div>
            </form>
        </div>
    </div>
</div>
