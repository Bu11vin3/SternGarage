@using SternGarage.ViewModels
@model CarDetailsViewModel
@{
    ViewData["Title"] = Model.Model;
}

<div class="container mt-5">
    <div class="row g-4">
        <div class="col-lg-5">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" class="img-fluid rounded" alt="@Model.Model">
            }
        </div>

        <div class="col-lg-7">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <span class="badge bg-secondary mb-2">@Model.ClassName</span>
                    <h2 class="fw-bold">@Model.Model</h2>
                </div>
                <div>
                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Изтрий</a>
                    }

                </div>
            </div>

            @if (Model.ReviewCount > 0)
            {
                <p>
                    @for (int i = 1; i <= 5; i++)
                    {
                        @(i <= Model.AverageRating ? "★" : "☆")
                    }
                    <span class="text-muted">@Model.AverageRating.ToString("F1") от @Model.ReviewCount @(Model.ReviewCount == 1 ? "отзив" : "отзива")</span>
                </p>
            }

            <h3 class="mb-4">@Model.Price.ToString("N0") €</h3>

            <table class="table">
                <tr>
                    <td><strong>Година</strong></td>
                    <td>@Model.Year</td>
                </tr>
                <tr>
                    <td><strong>Мощност</strong></td>
                    <td>@Model.Horsepower к.с.</td>
                </tr>
                <tr>
                    <td><strong>Двигател</strong></td>
                    <td>@Model.EngineType</td>
                </tr>
                <tr>
                    <td><strong>Клас</strong></td>
                    <td>@Model.ClassName</td>
                </tr>
            </table>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <h5>Описание</h5>
                <p class="text-muted">@Model.Description</p>
            }
        </div>
    </div>

    <hr class="my-4" />

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Отзиви (@Model.ReviewCount)</h3>
        <a asp-controller="Reviews" asp-action="Create" asp-route-carId="@Model.Id" class="btn btn-dark btn-sm">
            Добави отзив
        </a>
    </div>

    @if (Model.Reviews.Any())
    {
        @foreach (var review in Model.Reviews)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h5>@review.Title</h5>
                        <span class="text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                @(i <= review.Rating ? "★" : "☆")
                            }
                        </span>
                    </div>
                    <p>@review.Content</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">@review.AuthorName | @review.CreatedAt.ToString("dd.MM.yyyy")</small>
                        @if (User.IsInRole("Administrator"))
                        {
                            <div>
                                <a asp-controller="Reviews" asp-action="Edit" asp-route-id="@review.Id" class="btn btn-outline-secondary btn-sm">Редактирай</a>
                                <a asp-controller="Reviews" asp-action="Delete" asp-route-id="@review.Id" class="btn btn-outline-danger btn-sm">Изтрий</a>
                            </div>
                        }

                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4">
            <p class="text-muted">Все още няма отзиви за този автомобил.</p>
            <a asp-controller="Reviews" asp-action="Create" asp-route-carId="@Model.Id" class="btn btn-outline-dark">
                Напишете първия отзив
            </a>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-dark">Обратно към автомобилите</a>
    </div>
</div>
