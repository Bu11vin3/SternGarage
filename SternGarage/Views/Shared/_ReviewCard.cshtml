@model Review

<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <div>
                <h5 class="card-title mb-1">@Model.Title</h5>
                @if (Model.Car != null)
                {
                    <a asp-controller="Cars" asp-action="Details" asp-route-id="@Model.CarId" class="text-muted text-decoration-none small">
                        @Model.Car.Model
                    </a>
                }
            </div>
            <span class="text-warning">
                @for (int i = 1; i <= 5; i++)
                {
                @(i <= Model.Rating ? "★" : "☆")               
                }
            </span>
        </div>
        <p class="card-text">@Model.Content</p>
        <div class="d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @Model.AuthorName | @Model.CreatedAt.ToString("dd.MM.yyyy")
            </small>
            <div>
                @if (User.IsInRole("Administrator"))
                {
                    <a asp-controller="Reviews" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Редактирай</a>
                    <a asp-controller="Reviews" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Изтрий</a>
                }

            </div>
        </div>
    </div>
</div>