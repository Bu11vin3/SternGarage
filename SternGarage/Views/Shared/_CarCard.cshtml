@model Car

<div class="card h-100 shadow-sm">
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@Model.Model">
    }

    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title mb-0">@Model.Model</h5>
            @if (Model.Class != null)
            {
                <span class="badge bg-secondary">@Model.Class.Name</span>
            }
        </div>
        <p class="text-muted small mb-2">
            @Model.Year | @Model.Horsepower к.с. | @Model.EngineType
        </p>
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="card-text text-muted small flex-grow-1">
                @(Model.Description.Length > 100 ? Model.Description.Substring(0, 100) + "..." : Model.Description))
            </p>
        }
        <div class="d-flex justify-content-between align-items-center mt-auto">
            <strong>@Model.Price.ToString("N0")</strong>
            <a asp-controller="Cars" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-dark btn-sm">
                Детайли
            </a>
        </div>
    </div>
</div>
