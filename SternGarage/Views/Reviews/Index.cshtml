@using SternGarage.Models
@using SternGarage.ViewModels
@model PaginatedList<Review>
@{
    ViewData["Title"] = "Отзиви";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Отзиви</h2>
        <a asp-action="Create" class="btn btn-dark">Напиши отзив</a>
</div>

    @if (Model.Any())
    {
        @foreach (var review in Model)
        {
        @await Html.PartialAsync("_ReviewCard", review)
        }

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex - 1)">Назад</a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                            <a class="page-link" asp-action="Index"
                               asp-route-page="@i">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-page="@(Model.PageIndex + 1)">Напред</a>
                    </li>
                </ul>
            </nav>
        }
    }
    else
    {
        <div class="text-center py-5">
            <h4>Няма отзиви все още</h4>
            <a asp-action="Create" class="btn btn-dark mt-2">Напиши отзив</a>
        </div>
    }
</div>
