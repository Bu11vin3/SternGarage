@model IEnumerable<Review>
@{
    ViewData["Title"] = "Отзиви";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Отзиви</h2>
        <a asp-action="Create" class="btn btn-dark">Напиши отзив</a>
</div>

    @if (Model.Any())
    {
        @foreach (var review in Model)
        {
        @await Html.PartialAsync("_ReviewCard", review)
        }
    }
    else
    {
        <div class="text-center py-5">
            <h4>Няма отзиви все още</h4>
            <a asp-action="Create" class="btn btn-dark mt-2">Напиши отзив</a>
        </div>
    }
</div>